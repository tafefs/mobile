<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitleForgot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Вход по коду"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSubtitleForgot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:gravity="center"
        android:text="Введите ваш Email, мы вышлем 6-значный код"
        android:textColor="@color/text_hint"
        android:textSize="14sp" />

    <!-- БЛОК 1: ВВОД EMAIL -->
    <LinearLayout
        android:id="@+id/blockEmailInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <EditText
            android:id="@+id/etEmailForgot"
            style="@style/AppInput"
            android:layout_marginBottom="32dp"
            android:hint="Email"
            android:inputType="textEmailAddress" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSendCode"
            style="@style/AppButton.Green"
            android:layout_marginBottom="16dp"
            android:text="Получить код" />
    </LinearLayout>

    <!-- БЛОК 2: ВВОД КОДА (Скрыт по умолчанию) -->
    <LinearLayout
        android:id="@+id/blockCodeInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/etCodeForgot"
            style="@style/AppInput"
            android:layout_marginBottom="32dp"
            android:hint="8-значный код"
            android:inputType="number"
            android:maxLength="8"
            android:letterSpacing="0.5"
            android:gravity="center"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnVerifyCode"
            style="@style/AppButton.Green"
            android:layout_marginBottom="16dp"
            android:text="Подтвердить и войти" />
    </LinearLayout>

    <!-- БЛОК 3: ВВОД НОВОГО ПАРОЛЯ (Скрыт по умолчанию) -->
    <LinearLayout
        android:id="@+id/blockNewPasswordInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/etNewPassword"
            style="@style/AppInput"
            android:layout_marginBottom="32dp"
            android:hint="Новый пароль (мин. 6 символов)"
            android:inputType="textPassword" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSaveNewPassword"
            style="@style/AppButton.Green"
            android:layout_marginBottom="16dp"
            android:text="Сохранить новый пароль" />
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnBackFromForgot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:text="Назад"
        android:textAllCaps="false"
        android:textColor="@color/text_hint" />

</LinearLayout>