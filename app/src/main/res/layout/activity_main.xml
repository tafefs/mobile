<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <!-- контейнер для фрагментов -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_navigation_main" />

    <!-- нижняя навигация -->
    <LinearLayout
        android:id="@+id/bottom_navigation_main"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="@color/app_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:weightSum="5">

        <!-- хоум -->
        <LinearLayout
            android:id="@+id/btnNavHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/ivNavHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_view" />
            <TextView
                android:id="@+id/tvNavHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="@color/text_hint"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- трэкинг -->
        <LinearLayout
            android:id="@+id/btnNavTracking"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/ivNavTracking"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_compass" />
            <TextView
                android:id="@+id/tvNavTracking"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tracking"
                android:textColor="@color/text_hint"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- расписание -->
        <LinearLayout
            android:id="@+id/btnNavSchedule"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/ivNavSchedule"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_my_calendar" />
            <TextView
                android:id="@+id/tvNavSchedule"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Schedule"
                android:textColor="@color/text_hint"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- уведомления -->
        <LinearLayout
            android:id="@+id/btnNavNotifications"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/ivNavNotifications"
                android:layout_width="16dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_popup_reminder" />
            <TextView
                android:id="@+id/tvNavNotifications"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notifications"
                android:textColor="@color/text_hint"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- профиль -->
        <LinearLayout
            android:id="@+id/btnNavProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/ivNavProfile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_info_details" />
            <TextView
                android:id="@+id/tvNavProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textColor="@color/text_hint"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>